RPC_URL=https://ethereum-rpc.publicnode.com
PRIVATE_KEY=0xPRIVATE_KEY_WALLET_KAMU

# Jumlah worker threads untuk CPU mining.
# Kosongkan = pakai semua logical core yang tersedia.
# THREADS=8

# Interval (dalam jumlah hash) sebelum worker lapor hashrate ke main thread.
# Naikin biar overhead lebih rendah, turunin biar update lebih responsif.
# REPORT_EVERY=500000

# Coba pakai GPU backend (butuh file gpu-backend.js custom, default: off).
# USE_GPU=1
